---
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      <div class="logo-icon">S</div>
      <div class="logo-text">
        <div class="logo-primary">SWITCHBACK</div>
        <div class="logo-secondary">SOLUTIONS</div>
      </div>
    </a>

    <nav class="nav" id="main-nav" aria-label="Main navigation">
      <a href="/work" class="nav-link">PORTFOLIO</a>
      <a href="/blog" class="nav-link">BLOG</a>
      <a href="/about" class="nav-link">ABOUT</a>
    </nav>

    <a href="/contact" class="cta-button">Work with Me</a>

    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav aria-label="Mobile navigation">
    <a href="/work" class="mobile-nav-link">PORTFOLIO</a>
    <a href="/blog" class="mobile-nav-link">BLOG</a>
    <a href="/about" class="mobile-nav-link">ABOUT</a>
    <a href="/contact" class="mobile-nav-link mobile-cta">Work with Me</a>
  </nav>
</div>

<script>
  const btn = document.getElementById('hamburger-btn')!;
  const menu = document.getElementById('mobile-menu')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    menu.setAttribute('aria-hidden', String(!isOpen));
    btn.classList.toggle('is-open', isOpen);
  });

  // Close on nav link click
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      menu.setAttribute('aria-hidden', 'true');
      btn.classList.remove('is-open');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 248, 247, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(31, 31, 31, 0.1);
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-dark);
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-dark);
    border: 2px solid var(--color-dark);
    border-radius: 4px;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-primary {
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--color-dark);
  }

  .logo-secondary {
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-dark);
    opacity: 0.8;
  }

  .nav {
    display: flex;
    gap: 2rem;
    margin-left: auto;
  }

  .nav-link {
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: var(--color-dark);
    transition: opacity 0.2s;
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .cta-button {
    background-color: var(--color-accent);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    transition: background-color 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .cta-button:hover {
    background-color: #d4944a;
    transform: translateY(-1px);
  }

  /* Hamburger button */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-dark);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }

  .hamburger.is-open .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.is-open .bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu drawer */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 99;
    background: rgba(248, 248, 247, 0.98);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .mobile-menu.is-open {
    display: flex;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-nav-link {
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    color: var(--color-dark);
    transition: opacity 0.2s;
  }

  .mobile-nav-link:hover {
    opacity: 0.7;
  }

  .mobile-cta {
    background-color: var(--color-accent);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: 0.03em;
    margin-top: 1rem;
  }

  .mobile-cta:hover {
    opacity: 1;
    background-color: #d4944a;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 1rem 1.5rem;
    }

    .nav {
      display: none;
    }

    .cta-button {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      font-size: 1.25rem;
    }

    .logo-primary {
      font-size: 0.875rem;
    }

    .logo-secondary {
      font-size: 0.65rem;
    }
  }
</style>
