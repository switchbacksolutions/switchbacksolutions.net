---
// No props — self-contained diagram
---

<figure class="rtd-figure">
  <div class="rtd-wrapper">
    <canvas
      id="rtd-diagram"
      width="720"
      height="440"
      aria-label="Animated diagram tracing a client inquiry through six internal nodes: Inquiry, CRM Entry, Qualify, Scope Call, Proposal, and Contract. Orange delay labels appear above each handoff arrow. A dashed red rework loop runs from Scope back to Qualify labeled 'missing info'. Four stat boxes at the bottom show: cycle time 8 days, processing ~5 hrs, 5 handoffs, 1 rework loop."
    ></canvas>
  </div>
  <figcaption>
    A real client inquiry traced step by step. Green dots = work in progress; red dot = the rework loop. Most of the 8-day cycle is waiting — only ~5 hours is actual processing.
  </figcaption>
</figure>

<style>
  .rtd-figure {
    margin: 2.5rem 0;
    padding: 1.5rem 1rem;
    background: #f7faf8;
    border-radius: 8px;
    text-align: center;
  }

  .rtd-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  .rtd-wrapper canvas {
    width: 100%;
    height: auto;
    display: block;
  }

  .rtd-figure figcaption {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #888;
    font-style: italic;
  }
</style>

<script>
  const canvas = document.getElementById('rtd-diagram') as HTMLCanvasElement | null;
  if (canvas && canvas.getContext) {
    const ctx = canvas.getContext('2d')!;
    const W = 720, H = 440;

    const NODE_GREEN = '#2E5D47';
    const WORK_DOT   = '#4CAF7D';
    const DELAY_COL  = '#E8884A';
    const LOOP_COL   = '#C94C1A';
    const STAT_BG    = '#EEF5F1';

    const nodes = [
      { x:  65, y: 162, r: 28, label: 'INQUIRY',  role: 'Website',   proc: 'instant' },
      { x: 185, y: 162, r: 28, label: 'CRM',       role: 'Admin',     proc: '10 min'  },
      { x: 305, y: 162, r: 28, label: 'QUALIFY',   role: 'Sales',     proc: '30 min'  },
      { x: 425, y: 162, r: 28, label: 'SCOPE',     role: 'Eng Lead',  proc: '45 min'  },
      { x: 545, y: 162, r: 28, label: 'PROPOSAL',  role: 'Delivery',  proc: '3 hrs'   },
      { x: 655, y: 162, r: 28, label: 'CONTRACT',  role: 'Legal',     proc: '30 min'  },
    ];

    const delays = ['6 hr wait', '1 day', '2 days', '1 day', '3 days'];

    function ep(ai: number, bi: number) {
      const a = nodes[ai], b = nodes[bi];
      const dx = b.x - a.x, dy = b.y - a.y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      return {
        x1: a.x + dx / d * a.r, y1: a.y + dy / d * a.r,
        x2: b.x - dx / d * b.r, y2: b.y - dy / d * b.r,
        ux: dx / d, uy: dy / d,
      };
    }

    const edges = nodes.slice(0, -1).map((_, i) => ep(i, i + 1));

    function drawArrow(x: number, y: number, ux: number, uy: number, sz: number, col: string, alpha = 1) {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x - ux * sz + uy * sz * 0.45, y - uy * sz - ux * sz * 0.45);
      ctx.lineTo(x - ux * sz - uy * sz * 0.45, y - uy * sz + ux * sz * 0.45);
      ctx.closePath();
      ctx.fillStyle = col;
      ctx.fill();
      ctx.restore();
    }

    function rrect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.arcTo(x + w, y, x + w, y + r, r);
      ctx.lineTo(x + w, y + h - r);
      ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
      ctx.lineTo(x + r, y + h);
      ctx.arcTo(x, y + h, x, y + h - r, r);
      ctx.lineTo(x, y + r);
      ctx.arcTo(x, y, x + r, y, r);
      ctx.closePath();
    }

    // Dots flowing along forward edges
    interface Dot { ei: number; t: number; speed: number; }
    const dots: Dot[] = [
      { ei: 0, t: 0.0,  speed: 0.007 },
      { ei: 1, t: 0.4,  speed: 0.006 },
      { ei: 2, t: 0.15, speed: 0.005 },
      { ei: 3, t: 0.6,  speed: 0.006 },
      { ei: 4, t: 0.3,  speed: 0.006 },
      { ei: 0, t: 0.65, speed: 0.007 },
      { ei: 2, t: 0.8,  speed: 0.005 },
      { ei: 4, t: 0.75, speed: 0.006 },
    ];

    // Rework loop: SCOPE (node 3) → QUALIFY (node 2), curved below
    const loopSX  = nodes[3].x;
    const loopEX  = nodes[2].x;
    const loopY0  = nodes[3].y + nodes[3].r;  // bottom of SCOPE
    const loopY1  = nodes[2].y + nodes[2].r;  // bottom of QUALIFY
    const loopCPY = 268;
    const loopCPX = (loopSX + loopEX) / 2;

    let loopT = 0;
    let raf: number;

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // Title
      ctx.fillStyle = 'rgba(46,93,71,0.5)';
      ctx.font      = 'bold 9px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText('CLIENT INQUIRY → SIGNED CONTRACT  |  ACTUAL TIMELINE', W / 2, 12);

      // Forward edges
      for (let i = 0; i < edges.length; i++) {
        const e = edges[i];
        ctx.beginPath();
        ctx.moveTo(e.x1, e.y1);
        ctx.lineTo(e.x2, e.y2);
        ctx.lineWidth   = 1.5;
        ctx.strokeStyle = 'rgba(46,93,71,0.22)';
        ctx.stroke();
        drawArrow(e.x2, e.y2, e.ux, e.uy, 6, NODE_GREEN, 0.38);

        // Delay pill above edge midpoint
        const mx = (e.x1 + e.x2) / 2;
        const my = (e.y1 + e.y2) / 2 - 44;
        const tw  = ctx.measureText(delays[i]).width;
        const pw  = tw + 10;
        ctx.fillStyle = 'rgba(232,136,74,0.14)';
        rrect(mx - pw / 2, my, pw, 14, 4);
        ctx.fill();
        ctx.fillStyle   = DELAY_COL;
        ctx.font        = '8px sans-serif';
        ctx.textAlign   = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(delays[i], mx, my + 7);
      }

      // Rework loop (dashed bezier below nodes 3→2)
      ctx.beginPath();
      ctx.moveTo(loopSX, loopY0);
      ctx.quadraticCurveTo(loopCPX, loopCPY, loopEX, loopY1);
      ctx.lineWidth   = 1.5;
      ctx.strokeStyle = LOOP_COL;
      ctx.setLineDash([5, 3]);
      ctx.stroke();
      ctx.setLineDash([]);

      // Arrowhead at end of loop (direction toward QUALIFY bottom)
      const dxL = loopEX - loopCPX, dyL = loopY1 - loopCPY;
      const dL  = Math.sqrt(dxL * dxL + dyL * dyL);
      drawArrow(loopEX, loopY1, dxL / dL, dyL / dL, 6, LOOP_COL);

      // Loop label
      ctx.fillStyle    = LOOP_COL;
      ctx.font         = 'bold 8px sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText('missing info — sent back', loopCPX, loopCPY + 5);

      // Nodes
      for (const nd of nodes) {
        ctx.beginPath();
        ctx.arc(nd.x, nd.y, nd.r, 0, Math.PI * 2);
        ctx.fillStyle = NODE_GREEN;
        ctx.fill();

        ctx.fillStyle    = 'rgba(255,255,255,0.93)';
        ctx.font         = 'bold 9px sans-serif';
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(nd.label, nd.x, nd.y);

        // Role name above node
        ctx.fillStyle    = 'rgba(46,93,71,0.5)';
        ctx.font         = '8px sans-serif';
        ctx.textBaseline = 'bottom';
        ctx.fillText(nd.role, nd.x, nd.y - nd.r - 5);

        // Processing time below node
        ctx.fillStyle    = WORK_DOT;
        ctx.font         = '8px sans-serif';
        ctx.textBaseline = 'top';
        ctx.fillText(nd.proc, nd.x, nd.y + nd.r + 5);
      }

      // Animated dots — forward path
      for (const dot of dots) {
        dot.t = (dot.t + dot.speed) % 1;
        const e = edges[dot.ei];
        const x = e.x1 + (e.x2 - e.x1) * dot.t;
        const y = e.y1 + (e.y2 - e.y1) * dot.t;
        ctx.beginPath();
        ctx.arc(x, y, 4, 0, Math.PI * 2);
        ctx.fillStyle = WORK_DOT;
        ctx.fill();
      }

      // Animated dot — rework loop
      loopT = (loopT + 0.004) % 1;
      const lt = loopT;
      const rx  = (1 - lt) * (1 - lt) * loopSX + 2 * (1 - lt) * lt * loopCPX + lt * lt * loopEX;
      const ry  = (1 - lt) * (1 - lt) * loopY0  + 2 * (1 - lt) * lt * loopCPY + lt * lt * loopY1;
      ctx.beginPath();
      ctx.arc(rx, ry, 4, 0, Math.PI * 2);
      ctx.fillStyle = LOOP_COL;
      ctx.fill();

      // Stats boxes
      const stats = [
        { label: 'CYCLE TIME',  value: '8 days' },
        { label: 'PROCESSING',  value: '~5 hrs' },
        { label: 'HANDOFFS',    value: '5'       },
        { label: 'REWORK LOOPS', value: '1'       },
      ];
      const bW = 146, bH = 52, bY = 328, gap = 14;
      const totalW = stats.length * bW + (stats.length - 1) * gap;
      const bX0    = (W - totalW) / 2;

      for (let i = 0; i < stats.length; i++) {
        const bx = bX0 + i * (bW + gap);
        ctx.fillStyle = STAT_BG;
        rrect(bx, bY, bW, bH, 6);
        ctx.fill();
        ctx.strokeStyle = 'rgba(46,93,71,0.14)';
        ctx.lineWidth   = 1;
        rrect(bx, bY, bW, bH, 6);
        ctx.stroke();

        ctx.fillStyle    = 'rgba(46,93,71,0.45)';
        ctx.font         = '8px sans-serif';
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(stats[i].label, bx + bW / 2, bY + 9);

        ctx.fillStyle    = NODE_GREEN;
        ctx.font         = 'bold 17px sans-serif';
        ctx.textBaseline = 'middle';
        ctx.fillText(stats[i].value, bx + bW / 2, bY + 36);
      }

      // Footnote
      ctx.fillStyle    = 'rgba(100,100,100,0.5)';
      ctx.font         = '8px sans-serif';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('processing time shown below each node  |  wait time shown above each arrow', W / 2, H - 4);

      raf = requestAnimationFrame(draw);
    }

    draw();
    window.addEventListener('pagehide', () => cancelAnimationFrame(raf), { once: true });
  }
</script>
