---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const currentYear = new Date().getFullYear();
---

<BaseLayout
  title="Trail Technology — Switchback Solutions"
  description="Modern websites and trail usage counters built for land conservancies, MTB groups, and trail advocates. Tools that stretch your budget and prove your impact."
>
  <Header />

  <main class="trails-page">

    <!-- Hero -->
    <section class="hero-section">
      <div class="hero-text">
        <p class="eyebrow">For Trail Organizations</p>
        <h1 class="hero-title">Technology Built<br/>for the Trails You Steward</h1>
        <p class="hero-subtitle">
          Trail usage data is how you win grants, justify maintenance, and make the case for new infrastructure. I'm building an affordable trail counter — and looking for pilot partners to deploy it.
        </p>
        <a href="/contact" class="cta-button">Talk to Alec</a>
      </div>
      <div class="hero-image">
        <img
          src="/images/trails/trail-counter-natural.png"
          alt="Trak Count trail counter deployed in a mossy forest setting"
          width="1200"
          height="800"
        />
      </div>
    </section>

    <!-- Trail Counter: Overview -->
    <section class="section" id="counter">
      <div class="container">
        <div class="section-label">Trail Counter</div>
        <h2 class="section-title">Know Who's Using Your Trails — Without Breaking the Budget</h2>
        <div class="counter-intro">
          <p class="lead">
            Trail usage data is how you win grants, justify maintenance budgets, and make the case for new infrastructure. But commercial trail counters cost $500–$1,500 per unit, and the data is usually locked in a proprietary dashboard you have to keep paying for.
          </p>
          <p>
            I've built a trail counter on affordable, open hardware — battery-powered, weather-resistant, and deployable by volunteers. It detects and logs trail user counts without capturing any personally identifiable information.
          </p>
          <p>
            The data comes to you in formats you can actually use: spreadsheets, simple dashboards, grant-ready reports. No platform fees. No vendor lock-in. No annual contract.
          </p>
        </div>
      </div>
    </section>

    <!-- Trail Counter: Product + Features -->
    <section class="section product-spotlight-section" id="counter-features">
      <div class="container">
        <div class="product-name-label">Trak Count</div>
        <h2 class="product-heading">Built for the Field</h2>
        <div class="product-spotlight">
          <div class="spotlight-features spotlight-features-left">
            <div class="spotlight-feature">
              <strong>Grant-ready data</strong>
              <span>Usage counts, seasonal patterns, and trend reports built for funding applications</span>
            </div>
            <div class="spotlight-feature">
              <strong>Stewardship evidence</strong>
              <span>Demonstrate trail demand to justify maintenance, signage, and infrastructure investment</span>
            </div>
            <div class="spotlight-feature">
              <strong>Battery-powered</strong>
              <span>No wiring or power source required — deployable by volunteers anywhere on the trail</span>
            </div>
          </div>
          <div class="spotlight-image">
            <img
              src="/images/trails/trail-counter-product1.png"
              alt="Trak Count trail counter — weatherproof unit"
              width="480"
              height="480"
            />
          </div>
          <div class="spotlight-features spotlight-features-right">
            <div class="spotlight-feature">
              <strong>Privacy-first</strong>
              <span>Anonymous counts only — no photos, no tracking, no personally identifiable information</span>
            </div>
            <div class="spotlight-feature">
              <strong>Fraction of the cost</strong>
              <span>Open hardware keeps unit cost well below commercial alternatives</span>
            </div>
            <div class="spotlight-feature">
              <strong>Your data</strong>
              <span>No proprietary platform, no recurring fees, no vendor dependency</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trail Counter: How It Works + Pilot CTA -->
    <section class="section" id="counter-how">
      <div class="container">
        <div class="how-it-works">
          <h3 class="how-heading">How It Works</h3>
          <div class="steps">
            <div class="step">
              <div class="step-number">1</div>
              <div class="step-text">
                <strong>Deploy</strong>
                A volunteer mounts the weatherproof unit at the trailhead. Battery-powered — no wiring, no power source needed.
              </div>
            </div>
            <div class="step-arrow">&rarr;</div>
            <div class="step">
              <div class="step-number">2</div>
              <div class="step-text">
                <strong>Count</strong>
                The sensor detects passing trail users and logs anonymous counts with timestamps. No photos, no tracking.
              </div>
            </div>
            <div class="step-arrow">&rarr;</div>
            <div class="step">
              <div class="step-number">3</div>
              <div class="step-text">
                <strong>Report</strong>
                Data syncs to a simple dashboard. Export usage summaries, seasonal trends, and peak-use charts whenever you need them.
              </div>
            </div>
          </div>
        </div>

        <div class="pilot-banner">
          <div class="pilot-banner-text">
            <strong>Now seeking pilot partners.</strong>
            I'm looking for 2–3 organizations to deploy units on real trails — in exchange for early access pricing and direct input on the product roadmap.
          </div>
          <a href="/contact" class="pilot-banner-cta">Become a Pilot Partner &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Trail Websites -->
    <section class="section section-alt" id="websites">
      <div class="container">
        <div class="section-label">Trail Websites</div>
        <h2 class="section-title">Websites Built for Trail Discovery — and Donor Conversion</h2>
        <div class="two-col">
          <div class="col-text">
            <p class="lead">
              Most trail org websites bury the trails. Visitors dig through PDFs and generic park pages just to answer "where can I ride this weekend?"
            </p>
            <p>
              I build sites where trail browsing is front and center — filterable, searchable, and mobile-friendly. The messaging strategy is fundraising-focused from the start: membership asks, donation prompts, and volunteer calls-to-action woven in where they convert, not crammed into a footer.
            </p>
            <p>
              Hosting is designed for nonprofit budgets — static site architecture means fast load times and a cost profile that won't require a board vote to renew.
            </p>
          </div>
          <div class="col-features">
            <ul class="feature-list">
              <li>
                <span class="feature-icon">&#9650;</span>
                <div>
                  <strong>Trail browsing</strong> — filterable by difficulty, activity, and feature
                </div>
              </li>
              <li>
                <span class="feature-icon">&#9650;</span>
                <div>
                  <strong>Fundraising-first structure</strong> — membership and donation pathways built in, not bolted on
                </div>
              </li>
              <li>
                <span class="feature-icon">&#9650;</span>
                <div>
                  <strong>Low hosting cost</strong> — predictable, minimal ongoing costs
                </div>
              </li>
              <li>
                <span class="feature-icon">&#9650;</span>
                <div>
                  <strong>Staff-editable</strong> — update trails, events, and news without a developer
                </div>
              </li>
            </ul>
            <div class="examples-inline">
              <div class="example-pill">
                <span class="example-pill-label">Live</span>
                <a href="https://opentrailsca.org" target="_blank" rel="noopener">opentrailsca.org</a>
              </div>
              <div class="example-pill">
                <span class="example-pill-label upcoming">Forthcoming</span>
                <span>MVTA website</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Alec -->
    <section class="section" id="about">
      <div class="container">
        <div class="about-content">
          <div class="about-text">
            <h2 class="section-title left-aligned">Why Switchback Solutions</h2>
            <p>
              I'm Alec — a senior software engineer and technical architect based in the Sierra Nevada foothills. My weekend baseline is a long trail run or a ride on the local singletrack. I understand what you're trying to protect because it's where I spend my time too.
            </p>
            <p>
              My professional background is fifteen-plus years building software for organizations that need to do a lot with a little: nonprofits, early-stage startups, lean government teams. I know how to build things that actually work in production, don't require a dedicated IT department to maintain, and won't become a liability when the one person who understands them leaves.
            </p>
            <p>
              Trail technology is a natural overlap of the work I've always done and the terrain I care about. I'm not pitching you a generic agency product. I'm building tools I'd want to use myself.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <h2>Let's Talk About Your Trails</h2>
        <p>Whether you need a new website, usage data, or just want to think through what technology could do for your organization — I'm happy to have a no-pressure conversation.</p>
        <a href="/contact" class="cta-button-large">Get in Touch</a>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-logo">
          <div class="logo-icon-small">S</div>
          <div class="footer-logo-text">
            <div>SWITCHBACK</div>
            <div>SOLUTIONS</div>
          </div>
        </div>
        <p class="footer-tagline">Engineering Leadership for the AI Era</p>
      </div>
      <div class="footer-bottom">
        <p>&copy; {currentYear} Switchback Solutions. All rights reserved.</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .trails-page {
    padding-top: 80px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero-section {
    background-color: var(--color-primary);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
    overflow: hidden;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 3rem 5rem 2rem;
    max-width: 680px;
    margin-left: auto;
    color: white;
  }

  .hero-image {
    overflow: hidden;
  }

  .hero-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .eyebrow {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: white;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
    margin-bottom: 2.5rem;
  }

  .cta-button {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 1rem 2rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    transition: background-color 0.2s, transform 0.2s;
  }

  .cta-button:hover {
    background-color: #d4944a;
    transform: translateY(-2px);
  }

  /* Sections */
  .section {
    padding: 5rem 0;
  }

  .section-alt {
    background-color: var(--color-secondary);
  }

  .section-label {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.6;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 2.5rem;
    max-width: 760px;
    line-height: 1.25;
  }

  .section-title.left-aligned {
    max-width: none;
  }

  /* Counter intro (full-width text block) */
  .counter-intro {
    max-width: 800px;
    font-size: 1.075rem;
    line-height: 1.85;
    color: var(--color-dark);
  }

  .counter-intro p {
    margin-bottom: 1.5rem;
  }

  .counter-intro p:last-child {
    margin-bottom: 0;
  }

  .lead {
    font-size: 1.175rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  /* Two column layout */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .col-text {
    font-size: 1.075rem;
    line-height: 1.85;
    color: var(--color-dark);
  }

  .col-text p {
    margin-bottom: 1.5rem;
  }

  .col-text p:last-child {
    margin-bottom: 0;
  }

  /* Product spotlight section */
  .product-spotlight-section {
    background-color: #E5E5E5;
    text-align: center;
  }

  .product-name-label {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.6;
    margin-bottom: 0.5rem;
  }

  .product-heading {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 3rem;
    line-height: 1.25;
  }

  .product-spotlight {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: center;
  }

  .spotlight-image {
    flex-shrink: 0;
    width: 280px;
  }

  .spotlight-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .spotlight-features {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .spotlight-features-left {
    text-align: right;
  }

  .spotlight-features-right {
    text-align: left;
  }

  .spotlight-feature strong {
    display: block;
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
  }

  .spotlight-feature span {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-dark);
    opacity: 0.8;
  }

  /* Feature list */
  .col-features h3 {
    font-family: 'Raleway', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .feature-list:last-child {
    margin-bottom: 0;
  }

  .feature-list li {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-dark);
  }

  .feature-icon {
    color: var(--color-accent);
    font-size: 0.6rem;
    margin-top: 0.45rem;
    flex-shrink: 0;
  }

  .feature-list strong {
    display: block;
    margin-bottom: 0.125rem;
  }

  /* How It Works */
  .how-it-works {
    margin-bottom: 3.5rem;
  }

  .how-heading {
    font-family: 'Raleway', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: 200px;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-number {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: white;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-text {
    font-size: 0.975rem;
    line-height: 1.65;
    color: var(--color-dark);
    padding-top: 0.4rem;
  }

  .step-text strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 1rem;
  }

  .step-arrow {
    color: var(--color-accent);
    font-size: 1.5rem;
    padding-top: 0.5rem;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 0.35rem;
  }

  /* Pilot banner */
  .pilot-banner {
    background-color: var(--color-primary);
    color: white;
    border-radius: 8px;
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .pilot-banner-text {
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 620px;
  }

  .pilot-banner-cta {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 0.875rem 1.75rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    white-space: nowrap;
    transition: background-color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .pilot-banner-cta:hover {
    background-color: #d4944a;
    transform: translateY(-2px);
  }

  /* Inline examples (websites section) */
  .examples-inline {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .example-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-dark);
  }

  .example-pill a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .example-pill a:hover {
    opacity: 0.7;
  }

  .example-pill-label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background-color: var(--color-primary);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .example-pill-label.upcoming {
    background-color: var(--color-accent);
  }

  /* About */
  .about-content {
    max-width: 760px;
  }

  .about-text {
    font-size: 1.075rem;
    line-height: 1.85;
    color: var(--color-dark);
  }

  .about-text p {
    margin-bottom: 1.5rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  /* CTA section */
  .cta-section {
    padding: 5rem 0;
    text-align: center;
    background-color: var(--color-light);
  }

  .cta-section h2 {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.125rem;
    color: var(--color-dark);
    margin-bottom: 2rem;
    opacity: 0.85;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button-large {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 1.25rem 2.5rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1.125rem;
    transition: background-color 0.2s, transform 0.2s;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .cta-button-large:hover {
    background-color: #d4944a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  /* Footer */
  .footer {
    background-color: var(--color-primary);
    color: white;
    padding: 3rem 0 2rem;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon-small {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: white;
    border: 2px solid white;
    border-radius: 4px;
  }

  .footer-logo-text {
    display: flex;
    flex-direction: column;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .footer-tagline {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1rem;
    opacity: 0.9;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .product-spotlight {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .spotlight-image {
      width: 220px;
      margin: 0 auto;
    }

    .spotlight-features-left,
    .spotlight-features-right {
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .section {
      padding: 3.5rem 0;
    }

    .hero-section {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .hero-text {
      padding: 3.5rem 1.5rem 2.5rem;
      max-width: none;
      margin-left: 0;
    }

    .hero-image {
      height: 260px;
    }

    .container {
      padding: 0 1.5rem;
    }

    .cta-section {
      padding: 3.5rem 0;
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }

    .step-arrow {
      display: none;
    }

    .steps {
      flex-direction: column;
      gap: 1.5rem;
    }

    .pilot-banner {
      flex-direction: column;
      padding: 1.5rem;
    }

    .pilot-banner-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
