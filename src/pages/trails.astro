---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const currentYear = new Date().getFullYear();
---

<BaseLayout
  title="Trails — Switchback Solutions"
  description="Technology built for trail organizations — affordable trail usage counters and websites designed for discovery and donor conversion."
>
  <Header />

  <main class="page">

    <!-- Hero -->
    <section class="hero-section">
      <div class="container">
        <p class="eyebrow">For Trail Organizations</p>
        <h1 class="hero-title">Technology Built for the Trails You Steward</h1>
        <p class="hero-subtitle">
          Two products, one focus: helping land conservancies, mountain bike groups, and trail advocates do more with less.
        </p>
      </div>
    </section>

    <!-- Disambiguation cards -->
    <section class="options-section">
      <div class="container">
        <div class="options-grid">

          <a href="/trail-counter" class="option-card">
            <div class="option-image">
              <img
                src="/images/trails/trail-counter-natural.png"
                alt="Trak Count trail counter deployed in a forest"
                width="800"
                height="533"
              />
            </div>
            <div class="option-body">
              <div class="option-label">Trail Counter</div>
              <h2 class="option-title">Trak Count</h2>
              <p class="option-desc">
                Affordable, battery-powered trail counters built on open hardware. Privacy-first usage data for grants, maintenance reporting, and stewardship evidence — at a fraction of the cost of commercial units.
              </p>
              <div class="option-highlights">
                <span>Battery-powered</span>
                <span>IP67 waterproof</span>
                <span>Cellular connected</span>
                <span>Grant-ready reports</span>
              </div>
              <div class="option-cta">
                Learn about Trak Count &rarr;
              </div>
            </div>
          </a>

          <a href="/trail-websites" class="option-card">
            <div class="option-image option-image-websites">
              <div class="website-mockup">
                <div class="mockup-bar"></div>
                <div class="mockup-content">
                  <div class="mockup-line mockup-line-title"></div>
                  <div class="mockup-line mockup-line-med"></div>
                  <div class="mockup-line mockup-line-short"></div>
                  <div class="mockup-cards">
                    <div class="mockup-card"></div>
                    <div class="mockup-card"></div>
                    <div class="mockup-card"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="option-body">
              <div class="option-label">Trail Websites</div>
              <h2 class="option-title">Built for Discovery &amp; Donors</h2>
              <p class="option-desc">
                Websites where trail browsing is front and center — filterable, searchable, and mobile-friendly. Fundraising-first structure with membership and donation pathways built in from day one.
              </p>
              <div class="option-highlights">
                <span>Filterable trails</span>
                <span>Fundraising-first</span>
                <span>Staff-editable</span>
                <span>Low hosting cost</span>
              </div>
              <div class="option-cta">
                Learn about Trail Websites &rarr;
              </div>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="cta-section">
      <div class="container">
        <h2>Not sure which fits your needs?</h2>
        <p>We're happy to have a no-pressure conversation about what technology could do for your organization.</p>
        <a href="/contact" class="cta-button-large">Get in Touch</a>
      </div>
    </section>

  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-logo">
          <div class="logo-icon-small">S</div>
          <div class="footer-logo-text">
            <div>SWITCHBACK</div>
            <div>SOLUTIONS</div>
          </div>
        </div>
        <p class="footer-tagline">Engineering Leadership for the AI Era</p>
      </div>
      <div class="footer-bottom">
        <p>&copy; {currentYear} Switchback Solutions. All rights reserved.</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .page {
    padding-top: 80px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero-section {
    background-color: var(--color-primary);
    padding: 5rem 0 4.5rem;
    text-align: center;
  }

  .eyebrow {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    color: white;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    max-width: 560px;
    margin: 0 auto;
  }

  /* Options */
  .options-section {
    padding: 4rem 0 5rem;
    background-color: var(--color-light);
  }

  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .option-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    color: inherit;
  }

  .option-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.12);
  }

  .option-image {
    height: 240px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .option-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Website mockup placeholder */
  .option-image-websites {
    background-color: #E5E5E5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .website-mockup {
    background: white;
    border-radius: 8px;
    width: 80%;
    height: 180px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .mockup-bar {
    height: 20px;
    background-color: var(--color-primary);
    flex-shrink: 0;
  }

  .mockup-content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .mockup-line {
    height: 8px;
    background-color: #E5E5E5;
    border-radius: 4px;
  }

  .mockup-line-title {
    width: 60%;
    height: 12px;
    background-color: var(--color-primary);
    opacity: 0.3;
  }

  .mockup-line-med {
    width: 85%;
  }

  .mockup-line-short {
    width: 50%;
  }

  .mockup-cards {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex: 1;
  }

  .mockup-card {
    flex: 1;
    background-color: var(--color-secondary);
    border-radius: 4px;
  }

  /* Card body */
  .option-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .option-label {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .option-title {
    font-family: 'Raleway', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .option-desc {
    font-size: 0.975rem;
    line-height: 1.75;
    color: var(--color-dark);
    margin-bottom: 1.5rem;
    opacity: 0.85;
  }

  .option-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
    margin-top: auto;
  }

  .option-highlights span {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background-color: var(--color-secondary);
    color: var(--color-primary);
    padding: 0.3rem 0.65rem;
    border-radius: 4px;
  }

  .option-cta {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }

  /* CTA section */
  .cta-section {
    padding: 4.5rem 0;
    text-align: center;
    background-color: var(--color-secondary);
  }

  .cta-section h2 {
    font-family: 'Raleway', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--color-dark);
    margin-bottom: 2rem;
    opacity: 0.85;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button-large {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 1.25rem 2.5rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1.125rem;
    transition: background-color 0.2s, transform 0.2s;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .cta-button-large:hover {
    background-color: #d4944a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  /* Footer */
  .footer {
    background-color: var(--color-primary);
    color: white;
    padding: 3rem 0 2rem;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon-small {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: white;
    border: 2px solid white;
    border-radius: 4px;
  }

  .footer-logo-text {
    display: flex;
    flex-direction: column;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .footer-tagline {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1rem;
    opacity: 0.9;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .options-grid {
      grid-template-columns: 1fr;
    }

    .hero-section {
      padding: 4rem 0 3.5rem;
    }

    .container {
      padding: 0 1.5rem;
    }

    .options-section {
      padding: 3rem 0 4rem;
    }

    .cta-section {
      padding: 3.5rem 0;
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
