---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const currentYear = new Date().getFullYear();
---

<BaseLayout>
  <Header />

  <main class="contact-page">
    <div class="container">
      <h1 class="page-title">Let's Talk</h1>
      <div class="contact-content">
        <p class="lead">
          Ready to build technology that moves with you? Let's start a conversation about your project.
        </p>
        <form
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" required rows="5" placeholder="Tell me about your project…"></textarea>
          </div>
          <div id="form-error" class="form-error" role="alert" hidden></div>
          <button type="submit" class="cta-button-large submit-button">Send Message</button>
        </form>
        <div id="form-success" class="form-success" hidden>
          <p class="lead">Message sent — thanks!</p>
          <p class="contact-note">I typically respond within 24 hours. Looking forward to learning about what you're building.</p>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-logo">
          <div class="logo-icon-small">S</div>
          <div class="footer-logo-text">
            <div>SWITCHBACK</div>
            <div>SOLUTIONS</div>
          </div>
        </div>
        <p class="footer-tagline">Tech that Moves with You</p>
      </div>
      <div class="footer-bottom">
        <p>&copy; {currentYear} Switchback Solutions. All rights reserved.</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .contact-page {
    padding-top: 120px;
    padding-bottom: 5rem;
    min-height: calc(100vh - 200px);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-primary);
  }

  .contact-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .lead {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 2rem;
  }

  .hidden {
    display: none;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group label {
    font-family: 'Raleway', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(46, 93, 71, 0.3);
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1rem;
    color: var(--color-dark);
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(46, 93, 71, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-error {
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #dc2626;
    font-size: 0.95rem;
  }

  .submit-button {
    width: 100%;
    cursor: pointer;
    border: none;
  }

  .submit-button:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }

  .cta-button-large {
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    padding: 1.25rem 2.5rem;
    border-radius: 6px;
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 500;
    font-size: 1.125rem;
    transition: background-color 0.2s, transform 0.2s;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .cta-button-large:hover:not(:disabled) {
    background-color: #d4944a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .form-success {
    text-align: center;
    padding: 2rem 0;
  }

  .contact-note {
    margin-top: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-dark);
    opacity: 0.7;
  }

  .footer {
    background-color: var(--color-primary);
    color: white;
    padding: 3rem 0 2rem;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon-small {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: white;
    border: 2px solid white;
    border-radius: 4px;
  }

  .footer-logo-text {
    display: flex;
    flex-direction: column;
    font-family: 'Raleway', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }

  .footer-tagline {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1rem;
    opacity: 0.9;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.875rem;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .contact-page {
      padding-top: 100px;
      padding-bottom: 3rem;
    }

    .container {
      padding: 0 1.5rem;
    }

    .page-title {
      margin-bottom: 2rem;
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success') as HTMLElement | null;
  const errorEl = document.getElementById('form-error') as HTMLElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    if (errorEl) errorEl.hidden = true;

    try {
      const data = new URLSearchParams(new FormData(form) as unknown as Record<string, string>);
      const res = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data.toString(),
      });

      if (!res.ok) throw new Error(`Status ${res.status}`);

      form.hidden = true;
      if (successEl) successEl.hidden = false;
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Something went wrong. Please try again or email hello@switchbacksolutions.net.';
        errorEl.hidden = false;
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
